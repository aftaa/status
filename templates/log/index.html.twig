{% extends 'base.html.twig' %}

{% block title %}Логи событий{% endblock %}

{% block body %}
    <div class="container mt-4">
        <h1>📋 Логи событий</h1>

        <table class="table table-striped table-hover">
            <thead>
            <tr>
                <th>#</th>
                <th>Задача</th>
                <th>Действие</th>
                <th>Старые данные</th>
                <th>Новые данные</th>
                <th>Дата</th>
            </tr>
            </thead>
            <tbody>
            {% for log in logs %}
                <tr>
                    <td>{{ loop.index + (page - 1) * limit }}</td>
                    <td>
                        <a href="{{ path('app_log_task', {taskId: log.taskId}) }}">
                            #{{ log.taskId }}
                        </a>
                    </td>
                    <td><span class="badge bg-secondary">{{ log.action }}</span></td>
                    <td><pre>{{ log.oldData|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre></td>
                    <td><pre>{{ log.newData|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre></td>
                    <td>{{ log.createdAt|date('d.m.Y H:i:s') }}</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" class="text-center">📭 Нет логов</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        {% if totalPages > 1 %}
            <nav>
                <ul class="pagination">
                    {% for i in 1..totalPages %}
                        <li class="page-item {{ i == page ? 'active' : '' }}">
                            <a class="page-link" href="{{ path('app_logs', {page: i, limit: limit}) }}">{{ i }}</a>
                        </li>
                    {% endfor %}
                </ul>
            </nav>
        {% endif %}
    </div>
{% endblock %}
